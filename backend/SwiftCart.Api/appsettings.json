{
  "Jwt": {
    "Issuer": "SwiftCart.Api",
    "Audience": "SwiftCart.Client",
    "SecretKey": "CHANGE_THIS_TO_A_LONG_RANDOM_SECRET",
    "ExpiryMinutes": 60
  },
  "MySql": {
    "ConnectionString": "Server=localhost;Port=3306;Database=swiftcart;User=swiftcart_user;Password=CHANGE_ME;",
    "ServerVersion": "8.0.36"
  },
  "Setup": {
    "EnableBootstrapEndpoints": false,
    "BootstrapKey": "CHANGE_THIS_SETUP_KEY"
  },
  "EmailOtp": {
    "EnableEmailSending": false,
    "IncludeOtpInDevelopmentResponse": false,
    "SmtpHost": "",
    "SmtpPort": 587,
    "UseSsl": true,
    "SmtpUsername": "",
    "SmtpPassword": "",
    "FromAddress": "",
    "FromName": "SwiftCart",
    "OtpExpiryMinutes": 10,
    "MaxAttempts": 5
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
